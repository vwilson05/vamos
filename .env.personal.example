# vamos — personal profile
# Loaded on top of .env when VAMOS_PROFILE=personal or --profile personal.
# Put YOUR personal values here (your PAT, your channel webhooks, your name).

# Your personal PAT — Work Items R/W + (for pr-review) Code R/W + Pull Request Threads R/W.
# Generate at: https://dev.azure.com/<org>/_usersSettings/tokens
ADO_PAT=

# Your name — used in EOD posts.
DEVELOPER_NAME=

# Your personal Teams or Slack webhook (your DM channel, not the team channel).
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Your assigned-items query is @Me by default (no override needed).
# Set this only if you want the agent to operate on someone else's queue.
# ADO_USER_EMAIL=
