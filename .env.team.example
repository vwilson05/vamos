# vamos — team profile
# Loaded on top of .env when VAMOS_PROFILE=team or --profile team.
# Put SHARED values here (service-account PAT, team channel webhooks).
# Use this profile on the always-on host that runs metrics/healthcheck/hygiene
# on cron and posts to the team's shared Teams/Slack channel.

# Service-account PAT — owned by a non-personal ADO identity. The bot's
# comments and posts will appear under this account's name. Same scopes as
# personal profile.
ADO_PAT=

# Shared team channel webhooks. These are different URLs from the personal ones.
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Hygiene-specific overrides for the team profile (otherwise inherits from .env).
# HYGIENE_REPOS=halo-cooling,halo-edi,halo-fhir
# HYGIENE_LIVE_MODE=false   # flip to true after a couple weeks of clean dry-runs
