# Copy this file to .env and fill in the values.
# Never commit .env.

# Azure DevOps organization URL (no trailing slash).
# Example: https://dev.azure.com/halomd
ADO_ORG_URL=https://dev.azure.com/your-org

# Project name within the org.
ADO_PROJECT=YourProject

# Personal Access Token with Work Items (Read/Write/Manage) scope.
# Generate at: https://dev.azure.com/<org>/_usersSettings/tokens
ADO_PAT=

# The email address whose assigned items the agent manages.
# Leave blank to use the PAT owner (@Me).
# Override with a teammate's email for read-only testing.
ADO_USER_EMAIL=

# Set to "true" to forbid all writes (PATCH/POST). Useful for first-run testing.
ADO_READ_ONLY=false

# Connection option for EOD posts: "Teams" or "Slack"
# Determines which platform to use for EOD posts
CONNECTION_OPTION=Slack

# Microsoft Teams Incoming Webhook URL for EOD posts.
# Used when CONNECTION_OPTION is set to "Teams"
# Leave blank to skip Teams posting.
TEAMS_WEBHOOK_URL=

# Slack Webhook URL for EOD posts.
# Used when CONNECTION_OPTION is set to "Slack"
# Leave blank to skip Slack posting.
SLACK_WEBHOOK_URL=

# --- Success stories (MCP) ---
# When set, the MCP server posts short shout-outs to this webhook every time
# someone uses vamos to start_work / open_pr / vote_on_pr / close_ticket
# / run_pr_review-with-post=True. Aim this at a celebration channel like
# #halo-nation, NOT your team's EOD channel.
# Per-user opt-out: set VAMOS_SUCCESS_STORIES=false in your personal .env.
VAMOS_SUCCESS_WEBHOOK_URL=
VAMOS_SUCCESS_STORIES=true

# Developer name for EOD posting
# This name will be included in the EOD message
DEVELOPER_NAME=

# Optional: path to the Claude Code binary. Defaults to "claude" on PATH.
CLAUDE_BIN=claude

# Optional: directory for daily markdown files. Defaults to ./work
WORK_DIR=

# Optional: directory for sync state sidecars. Defaults to ./state
STATE_DIR=

# Optional: Area path for healthcheck queries (e.g., "Data Platform\\Engineering")
# Leave blank to query all areas
HEALTHCHECK_AREA_PATH=Data Platform\\Engineering

# Optional: Iteration path for healthcheck queries (e.g., "Data Platform\\Ingestion Engineering Kanban")
# Leave blank to query all iterations
HEALTHCHECK_ITERATION_PATH=Data Platform\\Ingestion Engineering Kanban

# Enable automatic cleanup of previous days' files when SOD runs
# Set to "false" to keep all historical files
# When enabled, SOD will delete previous days': markdown files, EOD reports,
# healthcheck reports, sync logs, and state files
SOD_CLEANUP_ENABLED=true

# `vamos daily` dispatcher schedule (all times local).
# Schedule cron / Task Scheduler to invoke `vamos daily` every 30 min;
# the dispatcher decides whether to do sod/sync/eod/nothing based on these.
RUN_SOD_AT=08:00
RUN_EOD_AT=18:00
RUN_SYNC_INTERVAL_MIN=180
RUN_SKIP_WEEKENDS=true

# ---------------------------------------------------------------------------
# vamos suite — profile selection
# ---------------------------------------------------------------------------
# Optional. If set, vamos overlays .env.personal or .env.team on top of this
# .env. Use --profile on the CLI to override per-invocation. Leave unset to
# use this single .env for everything (back-compat).
# VAMOS_PROFILE=personal

# When true, ./launch.sh runs `vamos prep` before opening the UI so My day
# shows today's SOD markdown, your inbox, and a standup brief immediately.
# Default false — flip to true if you want one-command "ready to go".
VAMOS_AUTO_PREP=false

# ---------------------------------------------------------------------------
# Hygiene agent (vamos hygiene) — Jeff Jordan's ADO board standards
# ---------------------------------------------------------------------------
# Area + iteration paths for the hygiene snapshot. Default to the same paths
# as healthcheck if unset.
# HYGIENE_AREA_PATH=Data Platform\\Engineering
# HYGIENE_ITERATION_PATH=Data Platform\\Ingestion Engineering Kanban

# Comma-separated list of ADO repo names to scan for PRs/branches.
# - Leave UNSET (or empty) to auto-discover ALL repos in the project (default).
# - Set to a comma-separated list to limit scope.
# - Override per-run with `vamos hygiene --repo myrepo` (repeatable).
# HYGIENE_REPOS=halo-cooling,halo-edi

# Hygiene live mode. When true (and --auto-comment is passed), hygiene posts
# nudge comments on offending tickets. Always start as false.
HYGIENE_LIVE_MODE=false

# Daily-comment SLA. Active/Blocked tickets need a comment from the assignee
# by this local time, or the daily-comments rule fires. Default 17:00.
HYGIENE_DAILY_COMMENT_DEADLINE=17:00

# Stale-Blocked threshold (days). Default 5.
HYGIENE_STALE_BLOCKED_DAYS=5

# Branch-naming regex (PR source branches must match). Default matches Jeff's
# spec: feature|bugfix|hotfix / <ticket-number> - <slug>
HYGIENE_BRANCH_PATTERN=^(feature|bugfix|hotfix)/\d+-[a-z0-9-]+$

# ---------------------------------------------------------------------------
# PR-review agent (vamos pr-review)
# ---------------------------------------------------------------------------
# Polling interval (seconds) for `vamos pr-review --watch`. Default 300.
# VAMOS_PR_REVIEW_INTERVAL=300
